{
  "name": "altogether-home-base",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/prerender.mjs",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:all": "vitest run && playwright test --reporter=list",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:verbose": "vitest run --reporter=verbose",
    "test:clean": "rm -rf .vitest dist coverage && vitest run",
    "test:nuclear": "node src/test/clear-cache.js && npm install && npx vitest run --no-cache",
    "test:verify-msw": "node src/test/verify-msw-v2.mjs",
    "bdd": "cucumber-js --config cucumber.mjs",
    "bdd:dev": "cucumber-js --config cucumber.mjs --tags \"not @skip\" --parallel 1",
    "bdd:smoke": "cucumber-js --config cucumber.mjs --tags \"@smoke\"",
    "bdd:debug": "cucumber-js --config cucumber.mjs --tags \"not @skip\" --parallel 1 --world-parameters '{\"headless\": false, \"slowMo\": 500}'",
    "bdd:report": "cucumber-js --config cucumber.mjs --format html:cucumber-report.html",
    "bdd:ci": "cucumber-js --config cucumber.mjs --tags \"not @skip\" --parallel 2 --format pretty --format html:cucumber-report.html"
  },
